color, rgba(0, 255, 60, 0.2));\n  }\n  \n  .grvsc-line-diff-del::before {\n    background-color: var(--grvsc-line-diff-del-background-color, rgba(255, 0, 20, 0.2));\n  }\n  \n  .grvsc-line-number {\n    padding: 0 2px;\n    text-align: right;\n    opacity: 0.7;\n  }\n  \n</style>","tableOfContents":"<ul>\n<li>\n<p><a href=\"#%ED%94%84%EB%A1%9C%EC%A0%9D%ED%8A%B8-%EC%84%A4%EB%AA%85\">프로젝트 설명</a></p>\n<ul>\n<li><a href=\"#%EC%82%AC%EC%9A%A9-%EA%B8%B0%EC%88%A0-%EB%B0%8F-%ED%99%98%EA%B2%BD\">사용 기술 및 환경</a></li>\n</ul>\n</li>\n<li>\n<p><a href=\"#%EC%A3%BC%EC%9A%94-%EA%B0%9C%EB%B0%9C-%EB%82%B4%EC%9A%A9\">주요 개발 내용</a></p>\n</li>\n</ul>","frontmatter":{"title":"연합 학습을 위한 플랫폼 데모 개발","summary":"React를 이용한 연합 학습 과제 진행에 필요한 모니터링 및 연합 학습을 위한 웹 서비스 프론트엔드 개발","start":"2022.01.01","end":"2023.09.01","type":"team","skills":["React","RTK Query","React-Router v6","MUI"],"emoji":"📲","links":[]}}}]}},"pageContext":{"slug":"/project_2/fl_platform/"}},"staticQueryHashes":[]}